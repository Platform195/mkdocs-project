                        "description": "Bad request, check the request body"
                    },
                    "404": {
                        "description": "Not found"
                    }
                },
                "tags": [
                    "Ad Decisions"
                ]
            }
        },
        "/sponsored-ad": {
            "post": {
                "summary": "Get Sponsored Ad",
                "description": "Request one or more sponsored ad decisions for the specified zones. Typically used to surface sponsored products or listings within search or browse results.",
                "operationId": "getsponsoredAd",
                "parameters": [
                    {
                        "name": "x-api-key",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "x-site-id",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "requestBody": {
