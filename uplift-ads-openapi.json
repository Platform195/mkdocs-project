                    },
                    "404": {
                        "description": "Not found"
                    }
                },
                "tags": [
                    "Ad Decisions"
                ]
            }
        },
        "/display-ad": {
            "post": {
                "summary": "Get Display Ad",
                "description": "Request one or more display ad decisions for the specified zones. Returns sized image assets for banner or rich-media creatives.",
